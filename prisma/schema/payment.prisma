model Payment {
  id            String        @id @default(uuid()) 
  reservationId String        @unique @map("reservation_id") 
  amount        Decimal       @db.Decimal(10, 2)
  currency      String        @default("USD")
  paymentMethod PaymentMethod
  status        PaymentStatus @default(PENDING)
  refundStatus  RefundStatus  @default(NONE) @map("refund_status")
  refundAmount  Decimal?      @map("refund_amount") @db.Decimal(10, 2)
  transactionId String?       @unique @map("transaction_id")
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt     DateTime      @updatedAt @map("updated_at") @db.Timestamp(6)

  reservation Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade, name: "payment_reservation")

  @@map("payments")
}